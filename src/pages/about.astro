---
import Base from '../layouts/Base.astro';
---
<Base title="Par — Sinole.lv">
  <div class="about-section">
    <div class="about-grid">
      <div class="about-text">
        <h2>Kaut kāds teksts no wikipedia</h2>
        <p>
          Sinole ir apdzīvota vieta Gulbenes novadā, Gaujas abos krastos 6 km
          attālumā no Lejasciema. Gar Sinoli iet autoceļš P34. Līdz 1949. gadam —
          Sinoles pagasta centrs. Ir ūdensdzirnavas.
        </p>
      </div>

      <div class="map-section">
        <h2>Atbrauc uz Sinoli</h2>
        <div class="map-wrap">
          <iframe
            src="https://www.google.com/maps?q=57.2464606,26.4978504&z=15&output=embed"
            loading="lazy"
            allowfullscreen
            title="Sinole karte"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</Base>
