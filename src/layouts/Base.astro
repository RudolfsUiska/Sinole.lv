---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="lv">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="icon" href="/assets/Sinolelv.ico" type="image/x-icon" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Varela+Round&family=Roboto:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Sinole.lv</p>
  </footer>
</body>
</html>
