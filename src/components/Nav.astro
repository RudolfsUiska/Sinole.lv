---
const pathname = Astro.url.pathname;
---
<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/assets/Sinolelv.svg" alt="Sinole.lv" width="140" height="32" />
  </a>

  <button class="nav-toggle" id="nav-toggle" aria-label="Atvērt izvēlni" aria-expanded="false">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="7" x2="21" y2="7"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="17" x2="21" y2="17"/>
    </svg>
  </button>

  <ul class="nav-links" id="nav-links" role="list">
    <li><a href="/" aria-current={pathname === '/' ? 'page' : undefined}>Sākums</a></li>
    <li><a href="/about" aria-current={pathname.startsWith('/about') ? 'page' : undefined}>Par</a></li>
    <li><a href="/contact" aria-current={pathname.startsWith('/contact') ? 'page' : undefined}>Kontakti</a></li>
  </ul>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const links  = document.getElementById('nav-links')!;

  toggle.addEventListener('click', () => {
    const open = links.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!toggle.contains(e.target as Node) && !links.contains(e.target as Node)) {
      links.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });
</script>
